{
  "version": 8,
  "name": "成都开发区碳收支",
  "sources": {
    "chengdu-zones": {
      "type": "geojson",
      "data": "chengdu-zones.geojson"
    }
  },
  "layers": [
    {
      "id": "chengdu-zones-fill",
      "type": "fill",
      "source": "chengdu-zones",
      "paint": {
        "fill-color": [
          "match",
          [
            "get",
            "id"
          ],
          "cd-gaoxin",
          "#E63232",
          "cd-tianfu",
          "#3296E6",
          "cd-jingkai",
          "#E6B432",
          "cd-dongbu",
          "#32C864",
          "#999999"
        ],
        "fill-opacity": 0.4
      }
    },
    {
      "id": "chengdu-zones-outline",
      "type": "line",
      "source": "chengdu-zones",
      "paint": {
        "line-color": "#333",
        "line-width": 2
      }
    },
    {
      "id": "chengdu-zones-labels",
      "type": "symbol",
      "source": "chengdu-zones",
      "layout": {
        "text-field": [
          "get",
          "name"
        ],
        "text-size": 12
      },
      "paint": {
        "text-color": "#222"
      }
    }
  ]
}