{
  "name": "@geo-toolbox/wasm",
  "version": "0.2.0",
  "description": "WebAssembly geospatial toolbox — browser-side CRS, carbon, NDVI, vector ops, geohash, tile math",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/geo-toolbox/geo-toolbox"
  },
  "keywords": [
    "geospatial",
    "wasm",
    "webassembly",
    "gis",
    "carbon",
    "ndvi",
    "geohash",
    "map-tiles",
    "buffer",
    "crs",
    "proj",
    "geo"
  ],
  "main": "pkg/geo_wasm.js",
  "types": "pkg/geo_wasm.d.ts",
  "files": [
    "pkg/geo_wasm_bg.wasm",
    "pkg/geo_wasm.js",
    "pkg/geo_wasm.d.ts",
    "pkg/geo_wasm_bg.wasm.d.ts"
  ],
  "scripts": {
    "build": "wasm-pack build --target web --out-dir pkg --release",
    "build:dev": "wasm-pack build --target web --out-dir pkg --dev",
    "test": "wasm-pack test --node"
  },
  "devDependencies": {
    "wasm-pack": "^0.13.0"
  }
}
